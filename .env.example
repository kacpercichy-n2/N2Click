# Skopiuj ten plik do .env.local i uzupełnij wartości ze swojego projektu Supabase.
# .env.local jest ignorowany przez git — nie commituj prawdziwych wartości.
# Używaj wyłącznie klucza publishable (sb_publishable_...), nigdy sekretnego.
VITE_SUPABASE_URL=https://twoj-projekt.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_twoj_klucz
