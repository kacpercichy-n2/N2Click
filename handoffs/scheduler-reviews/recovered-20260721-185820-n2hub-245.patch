index 0000000..1800ffc
--- /dev/null
+++ b/supabase/migrations/20260721190000_events.sql
@@ -0,0 +1,92 @@
+-- =============================================================================
+-- Migracja: 20260721190000_events
+--
+-- Wydarzenia / spotkania w kalendarzu („Wydarzenia”): spotkania zespołu z
+-- opcjonalną cyklicznością (RRULE-lite, jak `tasks.recurrence`) i listą
+-- uczestników. Tabela jest SAMODZIELNA — nie wiąże się z projektami/zadaniami i
+-- nie tworzy godzin planera.
+--
+-- Model dostępu (decyzja pakietu): kalendarz jest powierzchnią WSPÓŁDZIELONĄ w
+-- organizacji, a mapowanie ról chmury (`handlowiec → worker`) sprawia, że każdy
+-- model per-rola albo blokowałby handlowca (który lokalnie ma `tasks.manage`),
+-- albo wymagał modelu twórcy/uczestnika, którego lokalna encja nie niesie.
+-- Dlatego wszystkie cztery komendy są otwarte `to authenticated`
+-- (`using (true)` / `with check (true)`). Bramka klienta jest wyłącznie UX
+-- (patrz CLAUDE.md) — prawdziwej granicy pilnowałby przyszły model twórcy.
+--
+-- Uczestnicy są przechowywani jako kolumna `attendee_ids uuid[]` (NIE tabela
+-- łącznikowa) — parytet z `profiles.work_days smallint[]`; tabelę łącznikową
+-- stosujemy tylko tam, gdzie odpytuje ją RLS (task_assignments), a RLS wydarzeń
+-- tego nie robi.
+--
+-- Konwencja domu (patrz supabase/README.md): RLS w tym samym pliku, revoke anon,
+-- polityki to authenticated + with check, bez force row level security.
+-- Reużywamy istniejącego triggera `app.set_updated_at()` — BEZ nowych funkcji.
+-- Idempotentnie (`if not exists` / `drop policy if exists`): plik bywa aplikowany
+-- ręcznie przez SQL editor zanim `db push` uzupełni rejestr.
+-- =============================================================================
+
+create table if not exists public.events (
+  id uuid primary key default gen_random_uuid(),
+  title text not null check (char_length(title) between 1 and 300),
+  description text not null default '',
+  location text not null default '',
+  meeting_url text not null default '',
+  event_date date not null,
+  start_minutes integer not null
+    check (start_minutes >= 0 and start_minutes % 15 = 0),
+  duration_minutes integer not null
+    check (duration_minutes >= 15 and duration_minutes % 15 = 0),
+  attendee_ids uuid[] not null default '{}',
+  recurrence jsonb,
+  created_at timestamptz not null default now(),
+  updated_at timestamptz not null default now(),
+  check (start_minutes + duration_minutes <= 1440)
+);
+
+drop trigger if exists events_set_updated_at on public.events;
+create trigger events_set_updated_at
+  before update on public.events
+  for each row execute function app.set_updated_at();
+
+create index if not exists events_event_date_idx on public.events (event_date);
+
+-- -----------------------------------------------------------------------------
+-- RLS: deny-by-default + odebranie dostępu roli anon. Kalendarz to powierzchnia
+-- współdzielona — wszystkie komendy otwarte dla zalogowanych (patrz nagłówek).
+-- -----------------------------------------------------------------------------
+
+alter table public.events enable row level security;
+revoke all on public.events from anon;
+
+drop policy if exists "events_select" on public.events;
+create policy "events_select" on public.events
+  for select to authenticated
+  using (true);
+
+drop policy if exists "events_insert" on public.events;
+create policy "events_insert" on public.events
+  for insert to authenticated
+  with check (true);
+
+drop policy if exists "events_update" on public.events;
+create policy "events_update" on public.events
+  for update to authenticated
+  using (true)
+  with check (true);
+
+drop policy if exists "events_delete" on public.events;
+create policy "events_delete" on public.events
+  for delete to authenticated
+  using (true);
+
+-- Publikacja realtime (parytet z encjami planera — wydarzenia renderują się na
+-- współdzielonym kalendarzu) — idempotentnie:
+do $$
+begin
+  begin
+    alter publication supabase_realtime add table public.events;
+  exception
+    when duplicate_object then null;
+  end;
+end $$;
