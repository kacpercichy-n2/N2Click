+
+/**
+ * Wydarzenia / spotkania na dany dzień — WYŁĄCZNIE prezentacyjne (inwariant 1:
+ * nigdy nie zasilają sum/przeciążenia/kolizji). Dla każdego wydarzenia:
+ * - gdy `date === event.date` → wydarzenie bazowe z jego własnymi minutami,
+ *   emitowane RAZ nawet gdy reguła też trafia w ten dzień (bez podwójnego
+ *   renderu na dacie kotwicy);
+ * - w innym wypadku, z regułą, rozwijamy przez `expandOccurrences` w oknie
+ *   [date..date].
+ * Semantyka filtra: przy aktywnym, NIEPUSTYM `personFilter` wydarzenie jest
+ * pokazane, gdy KTÓRYKOLWIEK z uczestników jest w filtrze; wydarzenie z PUSTĄ
+ * listą uczestników zostaje widoczne (spotkanie bez adresata jest „wszystkich”).
+ */
+export function calendarEventsOnDate(
+  state: AppData,
+  date: DateStr,
+  personFilter?: Set<string>,
+): EventOnDate[] {
+  const filterActive = personFilter !== undefined && personFilter.size > 0;
+  const out: EventOnDate[] = [];
+  for (const event of state.events) {
+    if (filterActive && event.attendeeIds.length > 0) {
+      if (!event.attendeeIds.some((id) => personFilter!.has(id))) continue;
+    }
+    if (date === event.date) {
+      // Data bazowa: emituj raz, własne minuty; reguła NIE dubluje tego dnia.
+      out.push({
+        event,
+        startMinutes: event.startMinutes,
+        durationMinutes: event.durationMinutes,
+        isOccurrence: false,
+      });
+      continue;
+    }
+    if (event.recurrence === undefined) continue;
+    const occurrences = expandOccurrences(event.recurrence, event.date, date, date);
+    for (const occ of occurrences) {
+      out.push({
+        event,
+        startMinutes: occ.startMinutes,
+        durationMinutes: occ.durationMinutes,
+        isOccurrence: true,
+      });
+    }
+  }
+  return out;
+}
