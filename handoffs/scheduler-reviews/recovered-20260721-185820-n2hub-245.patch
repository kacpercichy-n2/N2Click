+  const { startMinutes, durationMinutes } = draft;
+  if (!isGridMinute(startMinutes) || startMinutes < 0 || startMinutes > DAY_MINUTES - MINUTE_STEP) {
+    return null;
+  }
+  if (
+    !isGridMinute(durationMinutes) ||
+    durationMinutes < MINUTE_STEP ||
+    durationMinutes > DAY_MINUTES
+  ) {
