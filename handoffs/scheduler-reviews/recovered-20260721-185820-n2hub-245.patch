+/** Jedno wystąpienie wydarzenia na dany dzień (bazowe albo z reguły cyklicznej). */
+export interface EventOnDate {
+  event: CalendarEvent;
+  startMinutes: number;
+  durationMinutes: number;
+  isOccurrence: boolean; // true, gdy z reguły cyklicznej (nie data bazowa)
