+// Wydarzenia / spotkania: lista posortowana po dacie i godzinie. Każdy wiersz
+// otwiera modal (?wydarzenie=<id>); „+ Dodaj wydarzenie” jest bramkowane
+// `tasks.manage`. Panel widzi każda rola (parytet z „Zgłoszenia”).
+import { useMemo } from 'react';
+import { useStore } from '../store/AppStore';
+import { useCan } from '../store/useCan';
+import { NO_PERM_TITLE } from '../store/permissions';
+import type { CalendarEvent } from '../types';
+import { formatMinutes } from '../utils/time';
+import { formatShortWithWeekday } from '../utils/dates';
+import { useOpenEvent } from '../components/EventModal';
+import { CalendarClock, ChevronRight, Plus } from '../components/icons';
+
+export function EventsPage() {
+  const { state } = useStore();
+  const can = useCan();
+  const canManage = can('tasks.manage');
+  const { openNewEvent, openEvent } = useOpenEvent();
+
+  const sorted = useMemo(
+    () =>
+      state.events
+        .slice()
+        .sort((a, b) =>
+          a.date !== b.date ? a.date.localeCompare(b.date) : a.startMinutes - b.startMinutes,
+        ),
+    [state.events],
+  );
+
+  const attendeeNames = (event: CalendarEvent): string =>
+    event.attendeeIds
+      .map((id) => state.people.find((p) => p.id === id)?.name)
+      .filter((n): n is string => n !== undefined)
+      .join(', ');
+
+  return (
+    <section className="page">
+      <div className="page-head">
+        <h1>
+          <CalendarClock size={20} aria-hidden /> Wydarzenia
+        </h1>
+        <div className="page-head-actions">
+          <button
+            type="button"
+            className="btn primary"
+            onClick={() => openNewEvent()}
+            disabled={!canManage}
+            title={canManage ? undefined : NO_PERM_TITLE}
+          >
+            <Plus size={16} aria-hidden /> Dodaj wydarzenie
+          </button>
+        </div>
+      </div>
+
+      {sorted.length === 0 ? (
+        <div className="empty-state">
+          <p className="empty-title">Brak wydarzeń</p>
+          <p className="empty-hint">
+            Dodaj spotkanie tutaj albo prawym przyciskiem w kalendarzu.
+          </p>
+        </div>
+      ) : (
+        <ul className="event-list">
+          {sorted.map((event) => {
+            const names = attendeeNames(event);
+            return (
+              <li key={event.id}>
+                <button
+                  type="button"
+                  className="event-row"
+                  onClick={() => openEvent(event.id)}
+                >
+                  <div className="event-row-main">
+                    <span className="event-row-title">
+                      {event.title}
+                      {event.recurrence !== undefined && (
+                        <span className="event-row-badge" title="Wydarzenie cykliczne">
+                          ⟳ cykliczne
+                        </span>
+                      )}
+                    </span>
+                    <span className="event-row-meta">
+                      {formatShortWithWeekday(event.date)} · {formatMinutes(event.startMinutes)}
+                      {names !== '' ? ` · ${names}` : ''}
+                      {event.location !== '' ? ` · ${event.location}` : ''}
+                    </span>
+                  </div>
+                  <ChevronRight size={18} aria-hidden />
+                </button>
+              </li>
+            );
+          })}
+        </ul>
+      )}
+    </section>
+  );
+}
